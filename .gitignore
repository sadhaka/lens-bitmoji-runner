# ===== Lens Studio generated / machine-local =====
# These are regenerated by Lens Studio on open and must NOT be committed -
# they cause merge noise and bloat. Everything else (.esproj, Assets/, Public/)
# IS committed so the project clones-and-opens.
Cache/
Caches/
Support/
BackUp/
Backup/
Workspaces/
PluginsUserPreferences/
*.lsproj.user
*.esproj.user
LensStudioLog*.log

# ===== OS / editor =====
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

# ===== Node (only if you add tooling later) =====
node_modules/
